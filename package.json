{
  "name": "@astronrpa/openclaw-plugin",
  "version": "1.0.1",
  "description": "OpenClaw HTTP plugin for Astron RPA",
  "keywords": [
    "openclaw",
    "plugin",
    "rpa",
    "astronrpa"
  ],
  "type": "module",
  "files": [
    "plugin.ts",
    "openclaw.plugin.json",
    "README.md",
    "README.zh-CN.md",
    "images"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./plugin.ts"
    ]
  }
}
